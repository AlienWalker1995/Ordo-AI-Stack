{
    # Listen only on the tailnet interface; the bind address is
    # controlled at compose level via CADDY_BIND.
    auto_https off
}

# Plain-HTTP healthz on :80 for the in-container Docker healthcheck
# (caddy:2-alpine's wget targets http://localhost/healthz). The 443
# host block below also serves /healthz publicly for tailnet probes.
:80 {
    handle /healthz {
        respond "ok" 200
    }
    handle {
        respond "use https" 421
    }
}

{$CADDY_TAILNET_HOSTNAME} {
    # Tailscale-issued cert (mounted in by host).
    tls /etc/caddy/certs/tailnet.crt /etc/caddy/certs/tailnet.key

    # ---- public bypass routes (auth not required) ----
    handle /oauth2/* {
        reverse_proxy oauth2-proxy:4180
    }
    handle /healthz {
        respond "ok" 200
    }
    # These bypass forward_auth (no SSO required) so external services
    # (Google OAuth, IG Graph API webhooks, etc.) can hit them. The
    # `uri strip_prefix /n8n` directive strips only the `/n8n` prefix
    # (not the full matched path) before proxying — n8n's internal routes
    # are registered at `/rest/...` and `/webhook/...`, NOT `/n8n/rest/...`
    # even with N8N_PATH=/n8n/, so without the strip the requests fall through
    # to n8n's SPA catch-all and the callback handler never runs (verified
    # live 2026-05-18: OAuth callbacks returned 200 + n8n SPA HTML instead of
    # processing the code/state).
    handle /n8n/rest/oauth2-credential/callback* {
        uri strip_prefix /n8n
        reverse_proxy n8n:5678
    }
    handle /n8n/webhook/* {
        uri strip_prefix /n8n
        reverse_proxy n8n:5678
    }

    # ---- LiteLLM model gateway (OpenAI-compatible API) for tailnet API clients ----
    # Bypasses SSO: programmatic clients (Cline, Cursor, scripts) can't do an
    # interactive Google login. Auth is LiteLLM's own Bearer key
    # (LITELLM_MASTER_KEY), which model-gateway enforces — so this is safe to
    # expose over the tailnet (Caddy binds the tailnet interface only).
    # handle_path strips /llm so LiteLLM sees /v1/... (e.g. /llm/v1/chat/completions).
    handle_path /llm/* {
        reverse_proxy model-gateway:11435
    }

    # ---- MCP gateway (aggregated tools) for tailnet MCP clients (Cline/Cursor) ----
    # Bypasses Google SSO (programmatic clients can't do an interactive login) but
    # requires a static Bearer token (MCP_GATEWAY_TOKEN, from SOPS) because the
    # gateway has NO auth of its own. /mcp is passed through UNSTRIPPED — the
    # gateway serves the MCP endpoint at /mcp. flush_interval -1 keeps the
    # streamable-HTTP / SSE responses unbuffered. Reachable only over the tailnet.
    @mcp_unauthed {
        path /mcp /mcp/*
        not header Authorization "Bearer {$MCP_GATEWAY_TOKEN}"
    }
    @mcp path /mcp /mcp/*
    handle @mcp_unauthed {
        respond "Unauthorized" 401
    }
    handle @mcp {
        reverse_proxy mcp-gateway:8811 {
            flush_interval -1
        }
    }

    # ---- Open WebUI at ROOT (no auth needed for the redirect) ----
    # Open WebUI's upstream v0.9.2 image is a prebuilt SvelteKit SPA with
    # base="" (assets are root-absolute: /_app, /static, /api, /ws). It MUST be
    # served at / — serving it under /chat made the *client-side* router 404 on
    # the /chat/ path even though the server returned 200 (logo loads, then the
    # SvelteKit router can't match /chat/ → its own 404 page). Open WebUI is the
    # root app via the catch-all reverse_proxy at the bottom of the route block.
    # Old /chat links 302 to / so they keep working.
    redir /chat* / 302

    # ---- everything else: forward_auth + then route to upstream ----
    # `route` (vs `handle`) keeps directives in source order and lets the
    # request continue past forward_auth to the matching handle_path block.
    # Caddy's `handle` blocks are MUTUALLY EXCLUSIVE — only one runs per
    # request — so a `handle { forward_auth }` would terminate the request
    # immediately after auth succeeds, returning the 202 to the browser
    # instead of proxying to the upstream UI.
    route {
        forward_auth oauth2-proxy:4180 {
            uri /oauth2/auth
            copy_headers X-Auth-Request-Email>X-Forwarded-Email X-Auth-Request-User>X-Forwarded-User X-Auth-Request-Preferred-Username>X-Forwarded-Preferred-Username
            # Convert oauth2-proxy's 401 (no session) into a 302 redirect
            # to /oauth2/start, preserving the original URL via rd= so the
            # user is bounced back to it after Google sign-in.
            @unauthorized status 401
            handle_response @unauthorized {
                redir https://{host}/oauth2/start?rd={scheme}://{host}{uri} 302
            }
        }

        # ---- protected upstreams (run only after forward_auth passes) ----
        handle_path /dash/* {
            reverse_proxy dashboard:8080
        }
        handle_path /n8n/* {
            reverse_proxy n8n:5678
        }
        handle_path /hermes/* {
            # Tell the Hermes dashboard server it's mounted at /hermes so the
            # SPA can rewrite its absolute asset/API/WS/plugin URLs at runtime
            # (server reads X-Forwarded-Prefix and injects window.__HERMES_BASE_PATH__).
            # Required since the upstream upgrade to commit 5fdcfd8 retired the
            # build-time spa-patches.mjs string-replaces in favor of header-driven base.
            reverse_proxy hermes-dashboard:9119 {
                header_up X-Forwarded-Prefix /hermes
            }
        }
        handle_path /comfy/* {
            reverse_proxy comfyui:8188
        }

        # ---- Grafana at /grafana/ (opt-in: --profile monitoring) ----
        # Grafana serves from the subpath (GF_SERVER_SERVE_FROM_SUB_PATH + root_url
        # /grafana/), so `handle` (NOT handle_path — keep the prefix) proxies straight
        # through. SSO-gated by the forward_auth above; Grafana itself is anonymous
        # read-only. Embedded in the dashboard's Grafana tab. 502s if the profile
        # isn't running.
        handle /grafana/* {
            reverse_proxy grafana:3000
        }

        # ---- codebase-memory 3D graph UI at /codebase-memory/ ----
        # Absolute-asset SPA served under a subpath: the codebase-memory-ui container
        # runs nginx, which proxies to the UI and rewrites its baked /assets,/api,/rpc,
        # /font-files to the /codebase-memory/ prefix (see codebase-memory-ui/nginx.conf).
        # `handle` (no strip) keeps the prefix so nginx's location matches. Opt-in
        # (--profile codebase-memory); 502s if the service isn't running.
        @codebasememory path /codebase-memory /codebase-memory/*
        handle @codebasememory {
            reverse_proxy codebase-memory-ui:9750
        }

        # ---- Open WebUI mounted at /chat (prefix stripped) ----
        # /chat/* → open-webui with the /chat prefix removed, so the upstream
        # sees /, /c/<id>, /models, etc. This is the canonical chat path.
        handle_path /chat/* {
            reverse_proxy open-webui:8080
        }

        # ---- root catch-all: Open WebUI assets + any unprefixed route ----
        # Open WebUI is a SvelteKit SPA built with base="" (no subpath
        # support), so it emits absolute paths like /_app/*, /static/*,
        # /api/*, /ws, /manifest.json. The /chat/* mount above strips its
        # prefix, so those assets are requested at root and resolved here.
        # Bare / is redirected to /chat/ in the bypass block above. All other
        # apps are properly prefix-aware (dashboard /dash/, hermes /hermes/,
        # n8n /n8n/, comfy /comfy/); only Open WebUI needs this root fallback.
        handle {
            reverse_proxy open-webui:8080
        }
    }
}

# ---- AI Toolkit LoRA trainer on a dedicated SSO-gated port ----
# The trainer UI is a prebuilt Next.js app with base="" (root-absolute /_next assets) and no
# basePath support — it CANNOT be served under a subpath (same class of problem as Open WebUI,
# see the ROOT comment above), and root on :443 is Open WebUI's. It gets its own HTTPS port:
# same tailnet bind, same cert, same forward_auth gate. Cookies are port-agnostic, so an
# existing :443 SSO session carries over; the OAuth callback stays on :443 (oauth2-proxy
# --redirect-url) and rd= returns the user here (whitelisted host:8443 in the edge plugin).
{$CADDY_TAILNET_HOSTNAME}:8443 {
    tls /etc/caddy/certs/tailnet.crt /etc/caddy/certs/tailnet.key

    handle /oauth2/* {
        reverse_proxy oauth2-proxy:4180
    }
    handle /healthz {
        respond "ok" 200
    }

    route {
        forward_auth oauth2-proxy:4180 {
            uri /oauth2/auth
            copy_headers X-Auth-Request-Email>X-Forwarded-Email X-Auth-Request-User>X-Forwarded-User X-Auth-Request-Preferred-Username>X-Forwarded-Preferred-Username
            @unauthorized status 401
            handle_response @unauthorized {
                # {hostport} (not {host}): this site is non-default-port, and the rd= must
                # return the user to :8443 after Google sign-in — {host} strips the port.
                redir https://{hostport}/oauth2/start?rd={scheme}://{hostport}{uri} 302
            }
        }
        reverse_proxy ai-toolkit:8675
    }
}
