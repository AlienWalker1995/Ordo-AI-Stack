{
  "id": "generate_image",
  "description": "Compile operator-authored API-format workflow (PARAM_* placeholders) with validated parameters.",
  "workflow_file": "mcp-api/generate_image.json",
  "parameter_schema": {
    "type": "object",
    "required": ["prompt"],
    "additionalProperties": true,
    "properties": {
      "prompt": { "type": "string", "minLength": 1 },
      "width": { "type": "integer", "minimum": 64, "maximum": 8192 },
      "height": { "type": "integer", "minimum": 64, "maximum": 8192 },
      "seed": { "type": "integer" },
      "steps": { "type": "integer", "minimum": 1, "maximum": 200 },
      "cfg": { "type": "number", "minimum": 0 },
      "negative_prompt": { "type": "string" }
    }
  }
}
