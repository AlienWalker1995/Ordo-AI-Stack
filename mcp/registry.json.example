{
  "servers": {
    "duckduckgo": {
      "image": "mcp/duckduckgo",
      "scopes": ["search"],
      "allow_clients": ["*"],
      "description": "Web search (DuckDuckGo) — gateway__search"
    },
    "n8n": {
      "image": "mcp/n8n",
      "scopes": ["workflow"],
      "allow_clients": ["*"],
      "description": "n8n workflow automation — list, create, execute workflows",
      "env_schema": {
        "N8N_API_URL": "optional",
        "N8N_API_KEY": "optional"
      }
    },
    "playwright": {
      "image": "mcp/playwright@sha256:097d978439237cc9b12e10825836a97245add2be0479272cce9d98c368f024d1",
      "scopes": ["browser", "web"],
      "allow_clients": ["*"],
      "description": "Playwright browser automation (browser_* tools) — headless Chromium navigation, snapshots, screenshots, form-fill, network inspection. Stack-pinned; default-on."
    },
    "comfyui": {
      "image": "ordo-ai-stack-comfyui-mcp:latest",
      "scopes": ["image"],
      "allow_clients": ["*"],
      "description": "ComfyUI workflows (run_workflow) + custom-node pip/restart via ops-controller when OPS_CONTROLLER_TOKEN is set"
    },
    "github-official": {
      "image": "mcp/github-official",
      "scopes": ["github"],
      "allow_clients": ["*"],
      "env_schema": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "required"
      }
    }
  }
}
