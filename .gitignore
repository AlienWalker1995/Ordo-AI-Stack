# Local dev (personal notes, full troubleshooting)
context/
.claude/scheduled_tasks.lock
.claude/settings.local.json
cp_test_output.log
test_output.log

# Untracked sibling projects that happen to live in this tree
/isolated_portfolio/

# Hermes Agent (host-mode install + local state; see docs/hermes-agent.md)
vendor/hermes-agent/
data/hermes/

# Tailscale-issued TLS material for Caddy front door — per-host, NEVER commit
auth/caddy/certs/

# Secrets — only encrypted .sops files plus README/.sops.yaml are tracked.
# Any plaintext file someone drops in secrets/ is rejected by default,
# so a slipped `secrets/temp.env` or `secrets/notes.txt` cannot leak.
secrets/*
!secrets/*.sops
!secrets/.sops.yaml
!secrets/README.md
!secrets/.gitkeep

# Internal superpowers tooling artifacts (specs, plans, skill notes) — local only.
docs/superpowers/

# Build/export artifacts and ad-hoc HTML drops accumulated at the repo root
# (min-max blog tarball, page exports). Audit 2026-05-11.
*.tar.gz
/final.html
/index.html

# Local dev artifacts not for the public repo
/screenshots/
/runtime/

# Host-specific Docker secret-path override (WSL2 path translation shim).
# Bind sources are operator-local; the file itself contains no secrets but
# reveals filesystem layout for secret files.
overrides/secrets-path.yml

# Phase-4 data-staging robocopy log (operator-local build artifact)
.staging.log
