# Copy to .env and set BASE_PATH. Everything else has sensible defaults.
# Do not commit .env.
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │  CONVENTION: .env is FEATURE FLAGS + OPERATIONAL CONFIG only.       │
# │  Secrets live in:                                                   │
# │    - secrets/.env.sops      (compose-substituted values like        │
# │                              OAUTH2_PROXY_*, DASHBOARD_AUTH_TOKEN,  │
# │                              OPS_CONTROLLER_TOKEN, SEARXNG_SECRET,  │
# │                              N8N_OWNER_PASSWORD, LITELLM_MASTER_KEY)│
# │    - secrets/<name>.sops    (file-form tokens consumed via _FILE    │
# │                              bridge inside containers: HF_TOKEN,    │
# │                              GitHub PAT, Discord bot token, etc.)   │
# │                                                                     │
# │  Both are SOPS+age encrypted. `make up` runs decrypt-secrets first  │
# │  and passes both layers to compose via                              │
# │     --env-file .env --env-file ~/.ai-toolkit/runtime/.env           │
# │                                                                     │
# │  Variables in this file with secret-pattern names (*_TOKEN, etc.)   │
# │  MUST have empty values. CI enforces this via                       │
# │  tests/test_env_example_no_secret_values.py.                        │
# └─────────────────────────────────────────────────────────────────────┘

# --- Required ---
# Project root (use forward slashes on Windows). e.g. . or C:/dev/ordo-ai-stack
BASE_PATH=.
# Optional: separate data directory (default: BASE_PATH/data)
# DATA_PATH=D:/ai-data

# --- Models (llama.cpp / GGUF) ---
# Main chat model filename under models/gguf/ (must exist before llamacpp starts).
# LLAMACPP_MODEL=qwen3.5-35b-q4_k_m.gguf
# Embedding model filename under models/gguf/ (llamacpp-embed).
# LLAMACPP_EMBED_MODEL=nomic-embed-text-v1.5.Q8_0.gguf
# Context size passed to llama-server --ctx-size.
# This is the real hard cap seen by Open WebUI, Cline, Claude Code, and any other clients routed through model-gateway.
# Default repo behavior is 256k so agent/dev-tool clients have a long-context baseline without extra setup.
# LLAMACPP_CTX_SIZE=262144
# Hard input-token budget for agent requests routed through model-gateway. Prevents slow decode by
# trimming prompts before they reach llama.cpp, regardless of the model's full context window.
# Uses character-based estimation (~1.5x undercount vs actual tokens), so 16384 ≈ 24-26k real tokens.
# Set 0 to disable trimming entirely.
# Optional: explicit Open WebUI default.
OPEN_WEBUI_DEFAULT_MODEL=local-chat
# GPU layers (-1 = all).
# LLAMACPP_GPU_LAYERS=-1
# Flash Attention mode forwarded to llama-server (`auto`, `on`, `off`).
# LLAMACPP_FLASH_ATTN=auto
# Feature flag: when set to 1, llama.cpp starts with quantized KV cache flags.
# LLAMACPP_ENABLE_KV_CACHE_QUANTIZATION=0
# KV cache types used when quantization is enabled. Valid values depend on the
# llama.cpp build. With the default repo-built image (llamacpp/Dockerfile,
# AmesianX TurboQuant fork) the TurboQuant types are available alongside the
# mainline ones. Pick one of:
#   tbq3_0    — TurboQuant 3-bit + Walsh-Hadamard rotation. Near-neutral quality.
#   tbq4_0    — TurboQuant 4-bit + WHT. Closest to fp16 quality of the tbq set.
#   tbqp3_0   — TurboQuant_prod (2-bit Lloyd-Max + 1-bit QJL). Max compression,
#               marginal quality dip — the paper's "near-2.5 bpw" variant.
#               Use this to fit 128k context + 19 GB weights in 32 GB VRAM.
#   tbqp4_0   — TurboQuant_prod (3-bit Lloyd-Max + 1-bit QJL). Safer than tbqp3_0.
#   tbq3_1 / tbq4_1 / tbqp3_1 / tbqp4_1  — head_dim=128 optimized variants.
#   tbq3_2 / tbq4_2 / tbqp3_2 / tbqp4_2  — head_dim=64 optimized variants.
#   q8_0, q4_0, q4_1, iq4_nl, q5_0, q5_1 — mainline types, always available.
# Any tbq* / tbqp* type requires Flash Attention; the entrypoint forces
# --flash-attn on when either K or V is a tbq* type (see
# scripts/llamacpp/run-llama-server.sh).
# LLAMACPP_KV_CACHE_TYPE_K=q4_0
# LLAMACPP_KV_CACHE_TYPE_V=q4_0
# Image selection. llama.cpp is pinned by DIGEST in docker-compose.yml
# (ggml-org mainline build 9765 / 73618f27a — loads Qwen3.6 MTP + qwen35moe
# natively). Override here ONLY to test a different build, e.g.:
# LLAMACPP_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
# Hard ceiling on tokens per single request. Defense-in-depth against
# runaway-reasoning loops where --reasoning-budget fails to close the
# <think> block (model never emits </think> in a confused large-context
# state). At 64K, normal responses are unaffected; runaway requests
# terminate with finish_reason=length instead of looping for an hour.
# LLAMACPP_N_PREDICT=65536
# Cap on tokens the model is allowed to spend inside <think>...</think> per
# response. Hoisted out of LLAMACPP_EXTRA_ARGS so it can be monitored and
# tuned from one place. Llama.cpp's grammar engine force-closes the block
# when this is hit. Note: in the current b1-0a8062d build this isn't fully
# reliable on Qwen3-family models, which is why N_PREDICT above exists as a
# hard backstop.
# LLAMACPP_REASONING_BUDGET=32768
# Optional raw llama-server args appended last. Useful for one-off experiments without editing compose.
# Note: if you previously had `--reasoning-budget N` in here, remove it —
# LLAMACPP_REASONING_BUDGET above is the canonical knob now.
# LLAMACPP_EXTRA_ARGS=
# Pull GGUFs once: docker compose --profile models run --rm gguf-puller
# GGUF_MODELS=org/repo-with-gguf-files
# Single canonical model identity. Don't change unless you renamed the alias in litellm_config.yaml.
# Default model id shown in Open WebUI (must match a model id from GET /v1/models, often the GGUF basename).
DEFAULT_MODEL=local-chat


# --- Compute ---
# Auto-detected by scripts/detect_hardware.py. Override: nvidia, amd, intel, cpu
# COMPUTE_MODE=nvidia
# COMPOSE_FILE=docker-compose.yml;overrides/compute.yml
#
# ComfyUI CLI (passed as CLI_ARGS). GPU stacks: include --normalvram so text encoders stay on GPU
# (omit --lowvram unless you need OOM fallback). Set explicitly or let detect_hardware.py append it.
# COMFYUI_CLI_ARGS=--disable-xformers --normalvram --enable-manager
# LTX Gemma: if encode fails with cudaErrorInvalidValue at sd1_clip.py torch.cat(...).to(intermediate_device), try:
#   PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
# or add --gpu-only to COMFYUI_CLI_ARGS (keeps intermediates on GPU; uses more VRAM).
# Override ComfyUI container RAM limit (mirrored into Compose `mem_limit` and the generated `deploy.resources` block).
# LTX+VideoVAE load spikes need headroom.
# COMFYUI_MEMORY_LIMIT=64G
# Expose MCP gateway (8811) on localhost for Cursor/doctor (see overrides/mcp-expose.yml):
# COMPOSE_FILE=docker-compose.yml;overrides/compute.yml;overrides/mcp-expose.yml

# --- Hermes self-heal watchdog (opt-in) ---
# Background task in ops-controller that restarts exited hermes-gateway /
# hermes-dashboard containers after the grace window elapses. Prevents the
# "operator stopped for rebuild and died" scenario. Disabled by default.
# Touch the pause file to temporarily disable without restarting ops-controller.
# OPS_HERMES_WATCHDOG_ENABLED=0
# OPS_HERMES_WATCHDOG_INTERVAL_SECONDS=30
# OPS_HERMES_WATCHDOG_GRACE_SECONDS=60
# OPS_HERMES_WATCHDOG_PAUSE_FILE=/data/watchdog.paused

# --- Optional ---
# N8N webhook URL (for OAuth callbacks; requires Tailscale Funnel)
# N8N_WEBHOOK_URL=https://your-machine.your-tailnet.ts.net
# Orchestration publish_enqueue default target — n8n owns retries, OAuth, and rate limits.
# N8N_PUBLISH_WEBHOOK_URL=https://your-machine.your-tailnet.ts.net/webhook/...
# Gate readiness on ComfyUI + workflow dir (default 0; set 1 for image-gen stacks)
# ORCHESTRATION_MEDIA_REQUIRED=0
# comfyui-mcp: allow implicit workflow_id from COMFY_MCP_DEFAULT_WORKFLOW_ID when flat prompt/width (compose default 0 = explicit workflow_id; default id mcp-api/generate_image)
# COMFY_MCP_ALLOW_DEFAULT_WORKFLOW_ID=0
# Default checkpoint model for ComfyUI MCP generate_image / queue_prompt.
# Must match a filename in data/comfyui-storage/ComfyUI/models/checkpoints/.
# COMFY_MCP_DEFAULT_MODEL=flux1-schnell-fp8.safetensors
# N8N MCP server — API key for full workflow access (Settings → API in n8n UI)
# N8N_API_KEY=
# N8N_API_URL=http://n8n:5678
# --- Internal tokens managed via SOPS ---
# The following env-form tokens are now managed via SOPS at
# secrets/.env.sops. Edit with: sops secrets/.env.sops
# `make up` (or scripts/secrets/decrypt.sh) decrypts them to
# ~/.ai-toolkit/runtime/.env, which docker-compose reads at boot.
#
# Inventory:
#   LITELLM_MASTER_KEY, DASHBOARD_AUTH_TOKEN, OPS_CONTROLLER_TOKEN,
#   THROUGHPUT_RECORD_TOKEN (if used), OAUTH2_PROXY_CLIENT_ID,
#   OAUTH2_PROXY_CLIENT_SECRET, OAUTH2_PROXY_COOKIE_SECRET.
#
# Don't set them inline here unless you're intentionally bypassing SOPS
# (e.g. CI/local dev without an age key).

# HF_TOKEN: managed via SOPS at secrets/hf_token.sops.
# Edit with: sops secrets/hf_token.sops
# Decrypted runtime path: ~/.ai-toolkit/runtime/secrets/hf_token
# Mounted into ops-controller, dashboard, comfyui-model-puller, and comfyui as
# /run/secrets/hf_token (see HF_TOKEN_FILE in compose).
# gguf-puller instead reads the optional HF_TOKEN env var (set it here or in your
# shell for gated repos); left empty it pulls public GGUF repos token-free, so a
# missing/SOPS-unavailable secret no longer hard-fails `compose run gguf-puller`.
# See docs/runbooks/secrets.md.

# GITHUB_PERSONAL_ACCESS_TOKEN: managed via SOPS at secrets/github_pat.sops.
# Edit with: sops secrets/github_pat.sops
# Decrypted runtime path: ~/.ai-toolkit/runtime/secrets/github_pat
# Mounted into mcp-gateway and (as GITHUB_TOKEN_FILE for ComfyUI-Manager) comfyui.
# See docs/runbooks/secrets.md.

# BRAVE_API_KEY=

# CIVITAI_TOKEN: managed via SOPS at secrets/civitai_token.sops.
# Edit with: sops secrets/civitai_token.sops
# Decrypted runtime path: ~/.ai-toolkit/runtime/secrets/civitai_token
# Mounted into comfyui-model-puller as /run/secrets/civitai_token.
# See docs/runbooks/secrets.md.

# SEARXNG_SECRET: required by services.searxng. Substituted into
# data/searxng/settings.yml at container start (replaces the literal sentinel
# "ultrasecretkey"). Generate with:  openssl rand -hex 32
# This is a SECRET — store the real value in secrets/.env.sops (dotenv-form,
# SOPS+age encrypted). The placeholder here MUST stay empty so the CI lint
# (tests/test_env_example_no_secret_values.py) keeps catching accidental
# commits of populated values.
# SEARXNG_SECRET=

# MCP servers for mcp-gateway (comma-separated). Search is provided by the
# self-hosted SearXNG instance (services.searxng) via the isokoliuk/mcp-searxng
# wrapper — see mcp/gateway/registry-custom.yaml. No external search API key is
# required. `playwright` (stack-pinned browser automation) is enabled by default.
# MCP_GATEWAY_SERVERS=duckduckgo,n8n,searxng,comfyui,orchestration,playwright
# Verbose docker/mcp-gateway logs (debug missing ComfyUI tools). See docs/runbooks/TROUBLESHOOTING.md
# MCP_GATEWAY_VERBOSE=1
# LITELLM_MASTER_KEY: managed via SOPS at secrets/.env.sops (see Internal tokens block above).
# Claude-compatible local model alias used by LiteLLM/model-gateway when a client still sends `claude-*` ids.
# CLAUDE_CODE_LOCAL_MODEL=qwen3:8b

# --- Model Registry (ops-controller /registry/*) ---
# JSON file that is the source of truth for which model runs on which GPU.
# Managed via the dashboard Models/GPU views or Hermes verbs (list_models, set_active_model, etc.).
# Reconciled from LLAMACPP_MODEL / LLAMACPP_EMBED_MODEL + overrides/gpu-assignments.yml on startup.
# Default is /data/model-registry.json (inside the ops-controller container, bind-mounted from data/).
# MODEL_REGISTRY_PATH=/data/model-registry.json

# --- RAG (--profile rag: Qdrant + rag-ingestion) ---
# Embedding model used by rag-ingestion and Open WebUI document embeddings via model-gateway.
# Default matches the dedicated llama.cpp embed server model.
# EMBED_MODEL=nomic-embed-text-v1.5.Q4_K_M.gguf
# Qdrant host port when published (compose default maps 6333)
# QDRANT_PORT=6333
# If compose fails with "Bind for 0.0.0.0:6333 failed: port is already allocated", set another host port (containers still use 6333 internally).
# Vector collection name (must match Open WebUI / ingestion)
# RAG_COLLECTION=documents
# Chunking for rag-ingestion (tokens ≈ words for plain text)
# RAG_CHUNK_SIZE=400
# RAG_CHUNK_OVERLAP=50
# RAG_SCAN_INTERVAL_SEC=15

# --- Worker throughput ---
# Queue poll interval (seconds). Lower = faster job pickup, higher CPU. Default 0.5s.
# WORKER_POLL_INTERVAL_SEC=0.5
# WORKER_CONCURRENCY=2
# WORKER_WAL_CHECKPOINT_SEC=300
# WORKER_VACUUM_SEC=86400

# --- MCP gateway reload behavior ---
# MCP_GATEWAY_POLL_SEC=5
# MCP_GATEWAY_RELOAD_DEBOUNCE_SEC=20

# --- Hermes Agent (docker-mode) ---
# Hermes runs as two compose services (hermes-gateway + hermes-dashboard). State in data/hermes/.
# See docs/hermes-agent.md for setup, Discord config, and upgrade instructions.
# HERMES_DASHBOARD_PORT overrides the host port for the web UI (default 9119).
# HERMES_DASHBOARD_PORT=9119

# --- Hermes per-turn budgets (hoisted from config.yaml for monitorability) ---
# Output token cap per LLM call. Hermes used to compute its own default
# (~12K), which truncated tool-heavy turns and triggered retry-exhaustion
# loops ('Response remained truncated after 3 continuation attempts').
# 65536 matches LLAMACPP_N_PREDICT — the model server hard-stops at the same
# ceiling, so there's no point requesting more. Lower if you want faster
# fail-fast on runaway turns; raising past LLAMACPP_N_PREDICT is a no-op.
# HERMES_MAX_TOKENS=65536
# Tool-use iteration ceiling per Hermes turn. After this many tool calls
# without producing a final response, Hermes gives up. Default matches the
# upstream agent runner.
# HERMES_MAX_TURNS=90
# Top-level wall-clock cap on a single Hermes turn. Distinct from the
# stream-stale timeout (which detects dead connections); this is the
# total-elapsed kill switch. 3600 = 1h.
# HERMES_GATEWAY_TIMEOUT=3600
# Number of times Hermes retries an LLM API call that returns 5xx / network
# errors. Hermes uses jittered exponential backoff capped at 120s per
# attempt (base 5s, doubling), so cumulative wait is roughly:
#   3  retries → ~ 35s    (default — too short for stacks with a VRAM
#                          guardian that pauses llamacpp during ComfyUI runs)
#   8  retries → ~ 5 min
#   10 retries → ~12 min  (covers ComfyUI generation + drain + GGUF reload)
# Raise this if you have services that periodically stop llamacpp (e.g.
# the COMFYUI_SERIALIZE_LLAMACPP guardian) — when llamacpp is reloading
# its weights, model-gateway returns 503 "Loading model" and Hermes needs
# to wait it out.
# HERMES_API_MAX_RETRIES=10

# --- n8n owner credentials (form login at the n8n UI) ---
# n8n 2.x always requires email-based internal login on top of any
# reverse-proxy SSO (its authenticationMethod is constrained to
# [email, ldap, saml]; there is no 'none' option). These values seed the
# owner user on first run and become the credentials your password
# manager autofills at the n8n login form (which lives behind whatever
# upstream SSO gate you have, e.g. oauth2-proxy).
#
# To apply (after editing this file):
#   docker run --rm --network ordo-ai-stack-backend \
#     -v "$PWD:/repo:ro" --env-file .env \
#     python:3.12-slim sh -c "pip install -q bcrypt requests && \
#       python /repo/scripts/n8n/bootstrap_owner.py"
#
# Idempotent — safe to re-run; updates the owner's email + bcrypt hash in
# n8n's DB whenever the values here change. Existing API keys (issued via
# n8n's /rest/api-keys) survive across re-runs because they reference the
# user by UUID, not credentials.
#
# NEVER commit real values. Operator's .env is gitignored; this file
# (.env.example) is committed and must only ever show placeholders.
# N8N_OWNER_EMAIL=
# N8N_OWNER_PASSWORD=

# --- Hermes Discord Gateway ---
# Set these, then `docker compose up -d hermes-gateway` to recreate the container with the new env.
#
# DISCORD_BOT_TOKEN: managed via SOPS at secrets/discord_token.sops.
# Edit with: sops secrets/discord_token.sops
# Decrypted runtime path: ~/.ai-toolkit/runtime/secrets/discord_token
# Mounted into hermes-gateway as /run/secrets/discord_token; the entrypoint
# bridges DISCORD_BOT_TOKEN_FILE → DISCORD_BOT_TOKEN before launching hermes.
# The legacy DISCORD_TOKEN inline alias is no longer accepted — re-encrypt
# the SOPS file if you need to change the token.
# See docs/runbooks/secrets.md.
#
# Comma-separated Discord user IDs authorized to DM or invoke the bot. Required —
# without this, the gateway denies all users by default.
# DISCORD_ALLOWED_USERS=YOUR_DISCORD_USER_ID
# Comma-separated channel IDs where the bot may respond. Optional.
# DISCORD_ALLOWED_CHANNELS=
# Comma-separated role IDs allowed to invoke the bot. Optional.
# DISCORD_ALLOWED_ROLES=
# Require @mention to respond (default true). Set false to respond to plain messages
# in permitted channels.
# DISCORD_REQUIRE_MENTION=false
# Channels where the bot responds without @mention (overrides DISCORD_REQUIRE_MENTION).
# DISCORD_FREE_RESPONSE_CHANNELS=
# Channel the bot treats as its "home" for proactive messages.
# DISCORD_HOME_CHANNEL=

# --- Hermes host-dev mount (advanced) ---
# Default target is /projects. Override to a path that mirrors your host
# filesystem when Hermes needs to call `docker compose` on sibling stacks
# via the docker socket — the host's daemon resolves bind-mount source paths
# against the *host* filesystem, not Hermes' filesystem, so matching the
# in-container target to the host path keeps sibling bind-mounts resolving
# identically on both sides.
#
# Examples:
#   Windows  (C:\dev)            HERMES_HOST_DEV_MOUNT=/c/dev
#   macOS    (/Users/me/dev)     HERMES_HOST_DEV_MOUNT=/Users/me/dev
#   Linux    (/home/me/dev)      HERMES_HOST_DEV_MOUNT=/home/me/dev
#
# Leave commented out to keep the default /projects mount.
# HERMES_HOST_DEV_MOUNT=

# --- SSO Front Door (Caddy + oauth2-proxy) ---
# Tailnet hostname Caddy serves. Must match the redirect_uri configured
# on the Google OAuth client: https://<this>/oauth2/callback.
# CADDY_TAILNET_HOSTNAME=ordo.<tailnet>.ts.net
# Cookie scope (parent domain of the hostname).
# CADDY_TAILNET_DOMAIN=<tailnet>.ts.net
# Tailnet IP from `tailscale ip -4`. NEVER 0.0.0.0 — Caddy must be
# tailnet-only.
# CADDY_BIND=100.x.y.z
# Path on the host where Tailscale-issued certs are mounted into Caddy.
# Default ./auth/caddy/certs (where you put tailnet.crt + tailnet.key
# from `tailscale cert <hostname>`).
# TAILSCALE_CERT_DIR=./auth/caddy/certs
# Google OAuth 2.0 Client (https://console.cloud.google.com/apis/credentials)
# OAUTH2_PROXY_CLIENT_ID=
# OAUTH2_PROXY_CLIENT_SECRET=
# 32-byte raw cookie signing secret (oauth2-proxy refuses base64-encoded
# 44-char strings). Generate exactly 16, 24, or 32 bytes:
#   LC_ALL=C tr -dc 'a-zA-Z0-9' </dev/urandom | head -c 32
# OAUTH2_PROXY_COOKIE_SECRET=

# --- Voice (--profile voice) ---
# Enable with: docker compose --profile voice up -d
# The model registry pins stt + tts to the secondary GPU by default
# (gpus[-1] when detect_hardware.py detects more than one; falls back to
# the primary GPU on single-GPU hosts). Override the pin via the ops-controller
# registry API or by editing overrides/gpu-assignments.yml.
#
# Speech-to-text (faster-whisper, OpenAI-compatible /v1/audio/transcriptions).
# Reached internally at http://stt:8000/v1. STT weights download once to
# ${DATA_PATH}/voice/hf-cache (persists across recreates).
# STT_MODEL=Systran/faster-whisper-small
#
# Quantization type. int8 is Pascal (GTX 1070) compatible; upgrade to float16
# on Turing+ for higher accuracy at similar VRAM cost.
# STT_COMPUTE_TYPE=int8
#
# Hermes' STT openai-provider base URL (set on hermes-gateway). Only used when
# the voice profile is up AND data/hermes/config.yaml has stt.provider=openai;
# otherwise it is an inert default and can be ignored.
# STT_OPENAI_BASE_URL=http://stt:8000/v1
#
# Text-to-speech (Kokoro, OpenAI-compatible /v1/audio/speech). Models are baked
# into the image (no runtime download). TTS_VOICE is the default voice the
# registry records + clients request; Kokoro selects the voice PER REQUEST (the
# `voice` API param), so this is a label/default, not a container setting.
# TTS_VOICE=af_bella
